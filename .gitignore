```gitignore
#################################################
# 🐍 Python
#################################################

# Virtual environments (ignore anywhere in repo)
**/tutorials/
venv/

# Python cache
**/__pycache__/
*.pyc

#################################################
# 🖥️ VS Code
#################################################

# Ignore all local VS Code settings
**/.vscode/

#################################################
# 🍎 macOS
#################################################

.DS_Store

#################################################
# 🔐 Environment Variables & Secrets
#################################################

.env
.env.*

*.key
*.pem

#################################################
# 📄 Temporary Office Files
#################################################

~$*

#################################################
# 📚 Local Study Documents
#################################################

AI-103_Master_Exam_Bible_Anish.docx

#################################################
# 🚫 Optional Large Files (uncomment if needed)
#################################################

# *.zip
# *.csv
# *.xlsx
# *.pptx
```
